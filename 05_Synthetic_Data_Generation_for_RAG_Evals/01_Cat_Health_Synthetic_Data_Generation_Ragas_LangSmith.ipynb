        "                \"answer\": str(row[\"reference\"]),\n",
        "                \"reference_contexts\": as_string_list(\n",
        "                    row[\"reference_contexts\"]\n",
        "                ),\n",
        "            },\n",
        "            \"metadata\": {\n",
